# ============================================
# 阿里百炼 (Bailian) 模型配置
# 使用方式: cp .env.bailian .env
# ============================================

# 部署模式
DEPLOY_MODE=alibabacloud_sdk

# ============================================
# 阿里云 OpenAPI 配置（用于 SysOM 服务）
# ============================================
ACCESS_KEY_ID=your_access_key_id
ACCESS_KEY_SECRET=your_access_key_secret
REGION_ID=cn-hangzhou

# ============================================
# 阿里百炼 LLM 配置
# ============================================

# 提供商: custom (使用自定义端点)
LLM_PROVIDER=custom

# 百炼 API Key
LLM_API_KEY=sk-sp-05f4c2eb66754d4caad76a2d3402329a

# 百炼 API 端点（OpenAI 兼容格式）
LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# 模型名称: kimi-k2.5
LLM_MODEL=kimi-k2.5

# 温度参数 (0-1)
LLM_TEMPERATURE=0.7

# 最大 Token 数
LLM_MAX_TOKENS=4000

# 超时时间(秒)
LLM_TIMEOUT=120

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
