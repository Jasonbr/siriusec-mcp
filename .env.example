# Siriusec_MCP 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 部署模式配置
# ============================================
DEPLOY_MODE=alibababacloud_sdk

# ============================================
# 阿里云 OpenAPI 配置
# ============================================
# 访问密钥 ID
ACCESS_KEY_ID=your_access_key_id_here

# 访问密钥 Secret
ACCESS_KEY_SECRET=your_access_key_secret_here

# 安全令牌（可选，使用 STS 时填写）
SECURITY_TOKEN=

# 角色 ARN（可选，使用角色扮演时填写）
ROLE_ARN=

# 地域 ID
REGION_ID=cn-hangzhou

# ============================================
# LLM 配置（支持多模型）
# ============================================

# LLM 提供商: dashscope(阿里云), openai, azure, custom
LLM_PROVIDER=dashscope

# LLM API Key（通用配置，根据提供商填写对应 key）
LLM_API_KEY=your_api_key_here

# 自定义 API 基础 URL（可选，使用自定义端点时填写）
# LLM_BASE_URL=https://your-custom-endpoint.com/v1

# 模型名称（根据提供商选择）
# 阿里云: qwen-turbo, qwen-plus, qwen-max, qwen-max-longcontext
# OpenAI: gpt-3.5-turbo, gpt-4, gpt-4-turbo
LLM_MODEL=qwen-turbo

# 温度参数（0-1，越高越创造性，越低越确定性）
LLM_TEMPERATURE=0.7

# 最大 Token 数
LLM_MAX_TOKENS=1500

# 请求超时时间（秒）
LLM_TIMEOUT=60

# ============================================
# 兼容旧配置（如已配置 LLM_API_KEY 可忽略）
# ============================================
# 阿里云 DashScope API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ============================================
# 日志配置
# ============================================
# 日志级别: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
