# Siriusec_MCP 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 部署模式配置
# ============================================
DEPLOY_MODE=alibababacloud_sdk

# ============================================
# 阿里云 OpenAPI 配置
# ============================================
# 访问密钥 ID
ACCESS_KEY_ID=your_access_key_id_here

# 访问密钥 Secret
ACCESS_KEY_SECRET=your_access_key_secret_here

# 安全令牌（可选，使用 STS 时填写）
SECURITY_TOKEN=

# 角色 ARN（可选，使用角色扮演时填写）
ROLE_ARN=

# 地域 ID
REGION_ID=cn-hangzhou

# ============================================
# LLM 配置
# ============================================
# 灵积模型服务 API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ============================================
# 日志配置
# ============================================
# 日志级别: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
